# Copy to register-repos.env and fill in — that file is gitignored (*.env).
#
# Source it before running the playbook:
#   set -a && source ansible/playbooks/register-repos.env && set +a
#   ansible-playbook -i inventory/ukubi/hosts.yaml ansible/playbooks/register-repos.yml
#
# Everything here is pre-Infisical bootstrap material: it exists to bring
# Infisical itself up (wave 1), so it can't come from Infisical. See
# ansible/README.md for what each value is and where to get it today.

# infra-bootstrap SSH deploy key — lets ArgoCD pull this repo (wave 1)
INFRA_BOOTSTRAP_SSH_KEY_FILE=~/.ssh/infra_bootstrap_id_ed25519

# Infisical's own bootstrap secrets (self-hosted instance, wave-1 install)
# — copy current values from the running k8s-cluster/infisical/.env.secret
ENCRYPTION_KEY=
AUTH_SECRET=
SITE_URL=
DB_CONNECTION_URI=
REDIS_URL=
DB_ROOT_CERT=
SMTP_HOST=
SMTP_USERNAME=
SMTP_PASSWORD=
CAPTCHA_SITE_KEY=
TELEMETRY_ENABLED=

# Infisical K8s operator machine-identity credentials
# — copy current values from the running k8s-cluster/infisical/.env.client
ARGOCD_INFISICAL_CLIENT_ID=
ARGOCD_INFISICAL_CLIENT_SECRET=

# optional overrides
ARGOCD_NAMESPACE=argocd
INFISICAL_NAMESPACE=infisical
